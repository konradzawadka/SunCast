{
  "name": "suncast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "precommit:check": "npm run lint && npm run test:coverage && npm run build",
    "prepush:check": "npm run build",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "prepare": "npm run hooks:install",
    "test": "vitest run --exclude \"**/e2e/**\"",
    "test:coverage": "vitest run --exclude \"**/e2e/**\" --coverage --coverage.reporter=text-summary --coverage.reporter=lcov --coverage.reporter=json-summary",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "cross-env PW_COVERAGE=1 playwright test",
    "coverage:e2e:report": "nyc report --reporter=html --reporter=text-summary --reporter=lcov",
    "coverage:e2e": "npm run test:e2e:coverage && npm run coverage:e2e:report",
    "coverage:legacy-audit": "node scripts/coverage-legacy-audit.mjs --lcov coverage/lcov.info",
    "coverage:legacy-check": "node scripts/coverage-legacy-audit.mjs --lcov coverage/lcov.info --only-legacy --fail-on-legacy",
    "validate:repo": "node scripts/validate-repo.mjs"
  },
  "nyc": {
    "all": true,
    "include": [
      "src/**/*.{ts,tsx}"
    ],
    "exclude": [
      "**/*.test.ts",
      "**/*.test.tsx",
      "src/main.tsx"
    ],
    "report-dir": "coverage",
    "temp-dir": ".nyc_output",
    "extension": [
      ".ts",
      ".tsx"
    ]
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "earcut": "^3.0.2",
    "maplibre-gl": "^5.19.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.0",
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/earcut": "^3.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "nyc": "^18.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^4.0.18"
  }
}
